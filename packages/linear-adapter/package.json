{
  "name": "@agent-detective/linear-adapter",
  "version": "1.0.1",
  "description": "Linear webhook adapter for agent-detective",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "test:watch": "tsx --test --watch \"test/**/*.test.ts\"",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "agent-detective",
    "linear",
    "adapter"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agent-detective/sdk": "workspace:*",
    "@linear/sdk": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andezdev/agent-detective.git"
  },
  "author": "Antonio Hernandez",
  "bugs": {
    "url": "https://github.com/andezdev/agent-detective/issues"
  }
}
