{
  "name": "@agent-detective/sdk",
  "version": "1.0.0",
  "description": "Runtime SDK for agent-detective plugin authors (defineRoute, registerRoutes, zodToPluginSchema)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agent-detective",
    "sdk",
    "plugin",
    "fastify",
    "zod"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agent-detective/types": "workspace:*",
    "fastify": "catalog:",
    "fastify-type-provider-zod": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andezdev/agent-detective.git"
  },
  "author": "Antonio Hernandez",
  "bugs": {
    "url": "https://github.com/andezdev/agent-detective/issues"
  }
}
